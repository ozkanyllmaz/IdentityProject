@model IdentityProject.Dtos.EmailRequestDto

@{
    Layout = null;
}
<link href="~/lib/bootstrap/dist/css/bootstrap.min.css" rel="stylesheet" />

<div class="container">
    <br />
    <h3>Smtp Mail</h3>
    <br /><br />
    <form method="post">
        <input type="text" asp-for="ReceiverEmail" placeholder="Alıcı Mail" class="form-control" />
        <br />
        <input type="text" asp-for="Subject" placeholder="Konu" class="form-control" />
        <br />
        <input type="text" asp-for="MessageDetail" placeholder="Mesaj" class="form-control" />
        <br />
        <button type="submit" class="btn btn-primary">Gönder</button>
    </form>

</div>
