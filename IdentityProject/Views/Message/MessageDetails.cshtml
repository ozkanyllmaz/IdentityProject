@model IdentityProject.Entities.Message

@{
    ViewData["Title"] = "MessageDetails";
    Layout = "~/Views/Shared/_Default.cshtml";
}

<div class="right-part mail-details bg-white">
    <div class="card-body">
        <button type="button" id="back_to_inbox" class="btn btn-outline-secondary font-18 m-r-10">
            <i class="mdi mdi-arrow-left"></i>
        </button>
        <div class="btn-group m-r-10" role="group" aria-label="Button group with nested dropdown">
            <button type="button" class="btn btn-outline-secondary font-18"><i class="mdi mdi-reply"></i></button>
            <button type="button" class="btn btn-outline-secondary font-18"><i class="mdi mdi-alert-octagon"></i></button>
            <button type="button" class="btn btn-outline-secondary font-18"><i class="mdi mdi-delete"></i></button>
        </div>
    </div>
    <div class="card-body border-top border-bottom bg-light">
        <h4 class="m-b-0">@Model.Subject</h4>
    </div>
    <div class="card-body border-bottom">
        <div class="d-flex no-block align-items-center m-b-40">
            <div class="m-r-10">
                <img src="@Model.Sender.ImageUrl" alt="user" class="rounded-circle"
                     width="45">
            </div>
            <div class="">
                <h5 class="m-b-0 font-16 font-medium">@Model.Sender.Name @Model.Sender.Surname <small> ( @Model.Sender.Email )</small></h5>
                <span>
                    to
                    @Model.Receiver.Email
                </span>
            </div>
            <div class="ml-auto text-muted" style="font-size: 12px;">
                <i class="far fa-clock m-r-5"></i>
                @Model.SendDate.ToString("dd MMM yyyy - HH:mm")
            </div>
        </div>
        <p>
            @Html.Raw(Model.MessageDetail)
        </p>

    </div>
    <div class="card-body">
        <h4><i class="fa fa-paperclip m-r-10 m-b-10"></i> Ekler <span>(@Model.Attachments.Count)</span></h4>

        <div class="row">
            @foreach (var item in Model.Attachments)
            {
                <div class="col-md-2 col-sm-4 col-xs-6 m-b-20 text-center">

                    <a href="@item.FileUrl" download="@item.FileName" title="İndirmek için tıklayın">

                        @if (item.FileType == ".jpg" || item.FileType == ".png" || item.FileType == ".jpeg" || item.FileType == ".gif")
                        {
                            <img class="img-thumbnail"
                                 src="@item.FileUrl"
                                 alt="@item.FileName"
                                 style="height: 100px; width: 100%; object-fit: cover;">
                        }
                        else
                        {
                            <div class="img-thumbnail" style="height: 100px; width: 100%; display: flex; align-items: center; justify-content: center; background-color: #f8f9fa;">
                                @if (item.FileType == ".pdf")
                                {
                                    <i class="fas fa-file-pdf fa-3x text-danger"></i>
                                }
                                else if (item.FileType == ".docx" || item.FileType == ".doc")
                                {
                                    <i class="fas fa-file-word fa-3x text-primary"></i>
                                }
                                else if (item.FileType == ".xlsx" || item.FileType == ".xls")
                                {
                                    <i class="fas fa-file-excel fa-3x text-success"></i>
                                }
                                else if (item.FileType == ".zip" || item.FileType == ".rar")
                                {
                                    <i class="fas fa-file-archive fa-3x text-warning"></i>
                                }
                                else
                                {
                                    <i class="fas fa-file fa-3x text-muted"></i>
                                }
                            </div>
                        }

                        <div class="m-t-5 text-truncate" style="font-size: 12px; color: #333; font-weight: 500;">
                            <i class="fa fa-download text-muted m-r-5"></i> @item.FileName
                        </div>
                    </a>
                </div>
            }
        </div>

        <div class="border m-t-20 p-15">
            <p class="p-b-20">click here to <a href="javascript:void(0)">Reply</a> or <a href="javascript:void(0)">Forward</a></p>
        </div>
    </div>
    <div>
        <a href="/Message/Inbox" class="btn btn-warning">Geri</a>
        <a href="/Message/DeleteMessage/@Model.MessageId" class="btn btn-danger">Sil</a>
    </div>
</div>

