
@{
    Layout = null;
    var currentAction = ViewContext.RouteData.Values["Action"]?.ToString();
}



<!DOCTYPE html>
<html dir="ltr" lang="en">

<head>
    <meta charset="utf-8">
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    <!-- Tell the browser to be responsive to screen width -->
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <meta name="description" content="">
    <meta name="author" content="">
    <!-- Favicon icon -->
    <link rel="icon" type="image/png" sizes="16x16" href="/mendy-admin/package/assets/images/favicon.png">
    <title>Mendy admin Template - The Ultimate Multipurpose admin template</title>
    <!-- This Page CSS -->
    <link href="/mendy-admin/package/assets/libs/summernote/dist/summernote-bs4.css" rel="stylesheet">
    <link href="/mendy-admin/package/assets/libs/dropzone/dist/min/dropzone.min.css" rel="stylesheet">
    <!-- Custom CSS -->
    <link href="/mendy-admin/package/dist/css/style.min.css" rel="stylesheet">
    <!-- HTML5 Shim and Respond.js IE8 support of HTML5 elements and media queries -->
    <!-- WARNING: Respond.js doesn't work if you view the page via file:// -->
    <!--[if lt IE 9]>
        <script src="https://oss.maxcdn.com/libs/html5shiv/3.7.0/html5shiv.js"></script>
        <script src="https://oss.maxcdn.com/libs/respond.js/1.4.2/respond.min.js"></script>
    <![endif]-->
</head>

<body>
    <!-- ============================================================== -->
    <!-- Preloader - style you can find in spinners.css -->
    <!-- ============================================================== -->
    <div class="preloader">
        <div class="lds-ripple">
            <div class="lds-pos"></div>
            <div class="lds-pos"></div>
        </div>
    </div>
    <!-- ============================================================== -->
    <!-- Main wrapper - style you can find in pages.scss -->
    <!-- ============================================================== -->
    <div id="main-wrapper">
        <!-- ============================================================== -->
        <!-- Topbar header - style you can find in pages.scss -->
        <!-- ============================================================== -->
        <header class="topbar">
            <nav class="navbar top-navbar navbar-expand-md navbar-dark" style="padding-left: 50px !important; padding-right: 50px !important;">
                <div class="navbar-header">
                    <!-- This is for the sidebar toggle which is visible on mobile only -->
                    <a class="nav-toggler d-block d-md-none" href="javascript:void(0)">
                        <i class="ti-menu ti-close"></i>
                    </a>
                    <!-- ============================================================== -->
                    <!-- Logo -->
                    <!-- ============================================================== -->
                    <div class="navbar-brand">
                        <a href="/Message/Inbox" class="logo">
                            <!-- Logo icon -->
                            <b class="logo-icon">
                                <!--You can put here icon as well // <i class="wi wi-sunset"></i> //-->
                                <!-- Dark Logo icon -->
                                <img src="/mendy-admin/package/assets/images/logo-icon.png" alt="homepage" class="dark-logo" />
                                <!-- Light Logo icon -->
                                <img src="/mendy-admin/package/assets/images/logo-light-icon.png" alt="homepage" class="light-logo" />
                            </b>
                            <!--End Logo icon -->
                            <!-- Logo text -->
                            <span class="logo-text">
                                <!-- dark Logo text -->
                                <img src="/mendy-admin/package/assets/images/logo-text.png" alt="homepage" class="dark-logo" />
                                <!-- Light Logo text -->
                                <img src="/mendy-admin/package/assets/images/logo-light-text.png" class="light-logo" alt="homepage" />
                            </span>
                        </a>
                    </div>
                    <!-- ============================================================== -->
                    <!-- End Logo -->
                    <!-- ============================================================== -->
                    <!-- ============================================================== -->
                    <!-- Toggle which is visible on mobile only -->
                    <!-- ============================================================== -->
                    <a class="topbartoggler d-block d-md-none" href="javascript:void(0)" data-toggle="collapse"
                       data-target="#navbarSupportedContent" aria-controls="navbarSupportedContent" aria-expanded="false"
                       aria-label="Toggle navigation">
                        <i class="ti-more"></i>
                    </a>
                </div>
                <!-- ============================================================== -->
                <!-- End Logo -->
                <!-- ============================================================== -->
                <div class="navbar-collapse collapse" id="navbarSupportedContent">
                    <!-- ============================================================== -->
                    <!-- toggle and nav items -->
                    <!-- ============================================================== -->
                    <ul class="navbar-nav float-left mr-auto">
                        <!-- ============================================================== -->
                        <!-- create new -->
                        <!-- ============================================================== -->
                        <li class="nav-item dropdown">

                            <div class="dropdown-menu" aria-labelledby="navbarDropdown">
                                <a class="dropdown-item" href="#">Action</a>
                                <a class="dropdown-item" href="#">Another action</a>
                                <div class="dropdown-divider"></div>
                                <a class="dropdown-item" href="#">Something else here</a>
                            </div>
                        </li>
                        <!-- ============================================================== -->
                        <!-- mega menu -->
                        <!-- ============================================================== -->
                        <li class="nav-item dropdown mega-dropdown">


                        </li>
                        <!-- ============================================================== -->
                        <!-- End mega menu -->
                        <!-- ============================================================== -->
                        <!-- ============================================================== -->
                        <!-- Search -->
                        <!-- ============================================================== -->
                        <li class="nav-item search-box">
                        </li>
                    </ul>
                    <!-- ============================================================== -->
                    <!-- Right side toggle and nav items -->
                    <!-- ============================================================== -->

                    @await Component.InvokeAsync("Navbar")

                </div>
            </nav>
        </header>
        <!-- ============================================================== -->
        <!-- End Topbar header -->
        <!-- ============================================================== -->
        <!-- ============================================================== -->
        <!-- Left Sidebar - style you can find in sidebar.scss  -->
        <!-- ============================================================== -->
        <!-- ============================================================== -->
        <!-- End Left Sidebar - style you can find in sidebar.scss  -->
        <!-- ============================================================== -->
        <!-- ============================================================== -->
        <!-- Page wrapper  -->
        <!-- ============================================================== -->
        <div class="page-wrapper">
            <!-- ============================================================== -->
            <!-- Bread crumb and right sidebar toggle -->
            <!-- ============================================================== -->
            
            <!-- ============================================================== -->
            <!-- End Bread crumb and right sidebar toggle -->
            <!-- ============================================================== -->
            <!-- ============================================================== -->
            <!-- Container fluid  -->
            <!-- ============================================================== -->
            <div class="container-fluid p-50">
                <!-- ============================================================== -->
                <!-- Email App Part -->
                <!-- ============================================================== -->
                <div class="email-app p-50">
                    <!-- ============================================================== -->
                    <!-- Left Part -->
                    <!-- ============================================================== -->
                    @if (currentAction != "UserProfile" && currentAction != "Settings")
                    {
                        @await Component.InvokeAsync("Menu")
                    }
                    
                    <!-- ============================================================== -->
                    <!-- Right Part -->
                    <!-- ============================================================== -->
                    @RenderBody()
                </div>
                <!-- ============================================================== -->
                <!-- Email App Part -->
                <!-- ============================================================== -->
            </div>
            <!-- ============================================================== -->
            <!-- End Container fluid  -->
            <!-- ============================================================== -->
            <!-- ============================================================== -->
            <!-- footer -->
            <!-- ============================================================== -->
            <footer class="footer text-center">
                ©Tüm hakları saklıdır <a>2026</a>.
            </footer>
            <!-- ============================================================== -->
            <!-- End footer -->
            <!-- ============================================================== -->
        </div>
        <!-- ============================================================== -->
        <!-- End Page wrapper  -->
        <!-- ============================================================== -->
    </div>
    <!-- ============================================================== -->
    <!-- End Wrapper -->
    <!-- ============================================================== -->
    <!-- ============================================================== -->
    <!-- customizer Panel -->
    <!-- ============================================================== -->
    

    <!-- ============================================================== -->
    <!-- All Jquery -->
    <!-- ============================================================== -->
    <script src="/mendy-admin/package/assets/libs/jquery/dist/jquery.min.js"></script>
    <!-- Bootstrap tether Core JavaScript -->
    <script src="/mendy-admin/package/assets/libs/popper.js/dist/umd/popper.min.js"></script>
    <script src="/mendy-admin/package/assets/libs/bootstrap/dist/js/bootstrap.min.js"></script>
    <!-- apps -->
    <script src="/mendy-admin/package/dist/js/app.min.js"></script>
    <script src="/mendy-admin/package/dist/js/app.init.horizontal.js"></script>
    <script src="/mendy-admin/package/dist/js/app-style-switcher.horizontal.js"></script>
    <!-- slimscrollbar scrollbar JavaScript -->
    <script src="/mendy-admin/package/assets/libs/perfect-scrollbar/dist/perfect-scrollbar.jquery.min.js"></script>
    <!--Wave Effects -->
    <script src="/mendy-admin/package/dist/js/waves.js"></script>
    <!--Menu sidebar -->
    <script src="/mendy-admin/package/dist/js/sidebarmenu.js"></script>
    <script src="/mendy-admin/package/dist/js/feather.min.js"></script>
    <!--Custom JavaScript -->
    <script src="/mendy-admin/package/dist/js/custom.min.js"></script>
    <!-- This Page JS -->
    <script src="/mendy-admin/package/assets/libs/summernote/dist/summernote-bs4.min.js"></script>
    <script src="/mendy-admin/package/assets/libs/dropzone/dist/min/dropzone.min.js"></script>

    <script>
        // 1. Dropzone'un kendi kendine çalışıp hata vermesini engelliyoruz.
        // Bu satır $(document).ready'nin DIŞINDA olmalı.
        Dropzone.autoDiscover = false;

        // 2. Sayfanın tamamen yüklenmesini bekliyoruz
        $(document).ready(function() {

            // Summernote Başlatma
            $('#summernote').summernote({
                placeholder: 'Mesajınızı yazınız',
                tabsize: 2,
                height: 250
            });

            // Dropzone Başlatma
            // Önce elemanın var olup olmadığını kontrol ediyoruz ki hata vermesin
            if ($("#dzid").length > 0) {
                $("#dzid").dropzone({
                    url: "/file/post", // Controller'daki dosya yükleme adresi
                    addRemoveLinks: true, // DOĞRUSU: sonuna 's' takısı gelmeli
                    dictDefaultMessage: "Dosyaları buraya sürükleyin veya tıklayın",
                    dictRemoveFile: "Dosyayı Kaldır" // Silme butonu yazısı
                });
            }
        });
    </script>

    <script src="~/js/site.js"></script>
    @await RenderSectionAsync("Scripts", required: false)

</body>

</html>

