@model IdentityProject.Dtos.UserEditDto

@{
    ViewData["Title"] = "UserProfile";
    Layout = "~/Views/Shared/_Default.cshtml";
}

<div class="container-fluid">
    <!-- ============================================================== -->
    <!-- Start Page Content -->
    <!-- ============================================================== -->
    <!-- Row -->
    <div class="row">
        <!-- Column -->
        <div class="col-lg-4 col-xlg-3 col-md-5">
            <div class="card">
                <div class="card-body">
                    <center class="m-t-30">

                        <img src="@Model.ImageUrl" id="profileImage" class="rounded-circle" width="150"
                             style="cursor: pointer;"
                             onclick="document.getElementById('fileInput').click();"
                             title="Resmi değiştirmek için tıklayın" />

                        <h4 class="card-title m-t-10">@Model.Name @Model.Surname</h4>
                        <h6 class="card-subtitle">@Model.About</h6>

                        <div class="row text-center justify-content-md-center">
                        </div>
                    </center>
                    
                </div>
                <div>
                    <hr>
                </div>
                <div class="card-body">
                    <small class="text-muted">Mail Adres </small>
                    <h6>@Model.Email</h6> <small class="text-muted p-t-30 db">Telefon</small>
                    <h6>@Model.PhoneNumber</h6> <small class="text-muted p-t-30 db">Adres</small>
                    <h6>@Model.Address</h6>
                    <div class="map-box">
                        @if (!string.IsNullOrEmpty(Model.Address))
                        {
                            <iframe width="100%"
                                    height="150"
                                    frameborder="0"
                                    style="border:0"
                                    allowfullscreen
                                    src="https://maps.google.com/maps?q=@Model.Address&t=&z=13&ie=UTF8&iwloc=&output=embed">
                            </iframe>
                        }
                        else
                        {
                            <div class="alert alert-warning">Konum bilgisi girilmemiş.</div>
                        }
                    </div>
                    <small class="text-muted p-t-30 db">Sosyal Medya Hesapları </small>
                    <br />
                    <button class="btn btn-circle btn-secondary"><i class="fab fa-facebook-f"></i></button>
                    <button class="btn btn-circle btn-secondary"><i class="fab fa-twitter"></i></button>
                    <button class="btn btn-circle btn-secondary"><i class="fab fa-youtube"></i></button>
                </div>
            </div>
        </div>
        <!-- Column -->
        <!-- Column -->
        <div class="col-lg-8 col-md-7">
            <div class="card">
                <!-- Tabs -->
                <ul class="nav nav-tabs" id="pills-tab" role="tablist">
                    <li class="nav-item">
                        <a class="nav-link active" id="pills-profile-tab" data-toggle="pill" href="#last-month"
                           role="tab" aria-controls="pills-profile" aria-selected="false">Profile</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" id="pills-setting-tab" data-toggle="pill" href="#previous-month"
                           role="tab" aria-controls="pills-setting" aria-selected="false">Setting</a>
                    </li>
                </ul>
                <!-- Tabs -->
                <div class="tab-content" id="pills-tabContent"> 
                    <div class="tab-pane fade show active" id="last-month" role="tabpanel" aria-labelledby="pills-profile-tab">
                        <div class="card-body">
                            <div class="row">
                                <div class="col-md-3 col-xs-6 b-r">
                                    <strong>Ad Soyad</strong>
                                    <br>
                                    <p class="text-muted">@Model.Name @Model.Surname</p>
                                </div>
                                <div class="col-md-3 col-xs-6 b-r">
                                    <strong>Telefon</strong>
                                    <br>
                                    <p class="text-muted">@Model.PhoneNumber</p>
                                </div>
                                <div class="col-md-3 col-xs-6 b-r">
                                    <strong>Mail</strong>
                                    <br>
                                    <p class="text-muted">@Model.Email</p>
                                </div>
                                <div class="col-md-3 col-xs-6">
                                    <strong>Adres</strong>
                                    <br>
                                    <p class="text-muted">@Model.Address</p>
                                </div>
                            </div>
                            <hr>
                            <p class="m-t-30">
                                @Model.MyAbout
                            </p>
                            
                            @await Component.InvokeAsync("UserStatistics")
                            
                        </div>
                    </div>
                    <div class="tab-pane fade" id="previous-month" role="tabpanel" aria-labelledby="pills-setting-tab">
                        <div class="card-body">
                            <form class="form-horizontal form-material" method="post" enctype="multipart/form-data">
                                <input type="file" id="fileInput" name="Image" style="display: none;" onchange="previewImage(this)" />
                                <div class="form-group">
                                    <label class="col-md-12">Ad</label>
                                    <div class="col-md-12">
                                        <input type="text" asp-for="Name" value="@Model.Name" class="form-control form-control-line">
                                    </div>
                                </div>
                                <div class="form-group">
                                    <label class="col-md-12">Soyad</label>
                                    <div class="col-md-12">
                                        <input type="text" asp-for="Surname" value="@Model.Surname" class="form-control form-control-line">
                                    </div>
                                </div>
                                <div class="form-group">
                                    <label for="example-email" class="col-md-12">Email</label>
                                    <div class="col-md-12">
                                        <input type="email" value="@Model.Email" class="form-control form-control-line"
                                               asp-for="Email" id="example-email" readonly>
                                    </div>
                                </div>
                                <div class="form-group">
                                    <label class="col-md-12">Şifre</label>
                                    <div class="col-md-12">
                                        <input type="password" asp-for="Password" class="form-control form-control-line">
                                    </div>
                                </div>
                                <div class="form-group">
                                    <label class="col-md-12">Şifre Tekrar</label>
                                    <div class="col-md-12">
                                        <input type="password" asp-for="ConfirmPassword" class="form-control form-control-line">
                                    </div>
                                </div>
                                <div class="form-group">
                                    <label class="col-md-12">Telefon</label>
                                    <div class="col-md-12">
                                        <input type="text" asp-for="PhoneNumber" value="@Model.PhoneNumber" class="form-control form-control-line">
                                    </div>
                                </div>
                                <div class="form-group">
                                    <label class="col-md-12">Hakkımda</label>
                                    <div class="col-md-12">
                                        <textarea rows="5" asp-for="MyAbout" class="form-control form-control-line">@Model.MyAbout</textarea>
                                    </div>
                                </div>
                                <div class="form-group">
                                    <label class="col-sm-12">Unvan</label>
                                    <div class="col-sm-12">
                                        <input type="text" asp-for="About" value="@Model.About" class="form-control form-control-line" />
                                    </div>
                                </div>
                                <div class="form-group">
                                    <label class="col-sm-12">Adres</label>
                                    <div class="col-sm-12">
                                        <input type="text" asp-for="Address" value="@Model.Address" class="form-control form-control-line" />
                                    </div>
                                </div>
                                <div class="form-group">
                                    <div class="col-sm-12">
                                        <button class="btn btn-success">Update Profile</button>
                                    </div>
                                </div>
                            </form>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        <!-- Column -->
    </div>
    <!-- Row -->
    <!-- ============================================================== -->
    <!-- End PAge Content -->
    <!-- ============================================================== -->
    <!-- ============================================================== -->
    <!-- Right sidebar -->
    <!-- ============================================================== -->
    <!-- .right-sidebar -->
    <!-- ============================================================== -->
    <!-- End Right sidebar -->
    <!-- ============================================================== -->
</div>

<script>
    function previewImage(input) {
        if (input.files && input.files[0]) {
            var reader = new FileReader();

            reader.onload = function (e) {
                // Seçilen resmin verisini img etiketinin src'sine atıyoruz
                $('#profileImage').attr('src', e.target.result);
            }

            reader.readAsDataURL(input.files[0]);
        }
    }
</script>   

